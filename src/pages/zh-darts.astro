  <p class="index" id="index">01 / 09</p>
</div>

<!-- ═══════════ NAV OVERLAY ═══════════ -->
<div class="nav-overlay" id="navOverlay">
  <div class="nav-panel">
    <a href="/zh" class="nav-section" style="padding-top:0">首页</a>
    <a href="/zh-work" class="nav-section">工作</a>
    <a href="/zh-decathlon" class="nav-sub">迪卡侬</a>
    <a href="/zh-mayora" class="nav-sub">迈大食品</a>
    <a class="nav-sub" style="color:var(--fg-3);cursor:default;pointer-events:none;">商道纵横</a>
    <a class="nav-sub" style="color:var(--fg-3);cursor:default;pointer-events:none;">天风证券</a>
    <hr>
    <a href="/zh-ai" class="nav-section">创造</a>
    <a href="/zh-stories" class="nav-section nav-current">故事</a>
    <button class="nav-section">信息</button>
  </div>
</div>

<!-- ═══════════ INFO OVERLAY ═══════════ -->
<div class="info-overlay" id="infoOverlay" aria-hidden="true">
  <div class="info-sheet">
    <button class="info-close" aria-label="关闭">&times;</button>
    <div><div class="info-col-label">教育</div><div class="info-col-body"><strong>悉尼大学</strong><br><span style="color:var(--fg-3);font-size:14px">2025–2027 · 项目管理硕士</span><br><br><strong>上海对外经贸大学</strong><br><span style="color:var(--fg-3);font-size:14px">2020–2024 · 国际经济与贸易学士</span></div></div>
    <div><div class="info-col-label">联系与社交</div><div class="info-col-body"><a href="mailto:trevor.tw.huang@outlook.com">trevor.tw.huang@outlook.com</a><br><a href="https://linkedin.com/in/trevor0h17/" target="_blank" rel="noopener">LinkedIn</a> &nbsp;·&nbsp; <a href="https://www.instagram.com/t.huang17/" target="_blank" rel="noopener">Instagram</a><br><a href="https://x.com/H3art128943" target="_blank" rel="noopener">X</a> &nbsp;·&nbsp; <a href="https://www.xiaohongshu.com/user/profile/6150a3e2000000001f03501f" target="_blank" rel="noopener">Xiaohongshu</a></div></div>
    <div style="grid-column:1/-1"><div class="info-col-label">工具</div><div class="info-col-body">Python · SQL · Tableau · Excel · Jira · Feishu · MS Project<br>Agile Methodologies</div></div>
  </div>
</div>

<script>
  // ── Theme ──
  const html = document.documentElement;
  const btn  = document.querySelector('.theme-btn');
  const sun  = document.getElementById('icon-sun');
  const moon = document.getElementById('icon-moon');

  function setTheme(t) {
    html.setAttribute('data-theme', t);
    sun.style.display  = t === 'dark' ? 'none' : 'block';
    moon.style.display = t === 'dark' ? 'block' : 'none';
  }

  // Sync icons with theme already set by BaseLayout's inline script
  setTheme(html.getAttribute('data-theme'));

  btn.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    localStorage.setItem('theme', next);
    setTheme(next);
  });

  // ── Nav & Info overlays ──
  const navOverlay = document.getElementById('navOverlay');
  const infoOverlay = document.getElementById('infoOverlay');

  function toggleNav() { navOverlay.classList.toggle('open'); }
  function closeNav(e) { if (!e || e.target === navOverlay) navOverlay.classList.remove('open'); }
  function toggleInfo() { navOverlay.classList.remove('open'); infoOverlay.classList.toggle('open'); }
  function closeInfo(e) { if (!e || e.target === infoOverlay) infoOverlay.classList.remove('open'); }

  document.querySelector('.topbar-nav').addEventListener('click', toggleNav);
  navOverlay.addEventListener('click', closeNav);
  infoOverlay.addEventListener('click', closeInfo);
  document.querySelector('.info-close').addEventListener('click', closeInfo);
  document.querySelector('.nav-panel button').addEventListener('click', toggleInfo);

  // ── Gallery ──
  (function() {
    var track = document.getElementById('track');
    var slots = document.querySelectorAll('.slot');
    var idxEl = document.getElementById('index');
    var imgs = document.querySelectorAll('.slot img');
    var mp = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (!track || !slots.length) return;

    var total = slots.length;
    var current = 0;

    function goTo(i) {
      current = Math.max(0, Math.min(i, total - 1));
      var slot = slots[current];
      track.scrollTo({ left: slot.offsetLeft - track.offsetWidth / 2 + slot.offsetWidth / 2, behavior: mp.matches ? 'auto' : 'smooth' });
    }

    window.prevImage = function() { goTo(current - 1); };
    window.nextImage = function() { goTo(current + 1); };

    // Build ruler ticks
    var ruler = document.getElementById('ruler');
    var dart = document.getElementById('dart');
    for (var i = 0; i < total; i++) {
      var tick = document.createElement('div');
      tick.className = 'ruler-tick';
      tick.style.left = (i / (total - 1) * 100) + '%';
      ruler.appendChild(tick);
    }

    function update() {
      var centerX = window.innerWidth / 2;
      var best = 0, bestDist = Infinity;
      imgs.forEach(function(img, i) {
        var rect = img.getBoundingClientRect();
        var dist = Math.abs(rect.left + rect.width / 2 - centerX);
        if (dist < bestDist) { bestDist = dist; best = i; }
      });

      if (best !== current) {
        current = best;
        idxEl.textContent = String(current + 1).padStart(2, '0') + ' / ' + String(total).padStart(2, '0');
      }

      // Dart follows scroll progress, not image index
      var maxScroll = track.scrollWidth - track.clientWidth;
      var progress = maxScroll > 0 ? track.scrollLeft / maxScroll : 0;
      dart.style.left = (progress * 100) + '%';
      dart.style.transition = 'none';

      imgs.forEach(function(img, i) {
        if (i === current) img.classList.remove('dim');
        else img.classList.add('dim');
      });
    }

    track.addEventListener('scroll', function() {
      requestAnimationFrame(update);
    }, { passive: true });

    // Arrow key navigation
    document.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); }
    });

    update();
  })();
</script>
</BaseLayout>

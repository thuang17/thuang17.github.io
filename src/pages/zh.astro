<script>
  // ── Theme ──
  const html = document.documentElement;
  const btn  = document.getElementById('tbtn');
  const sun  = document.getElementById('i-sun');
  const moon = document.getElementById('i-moon');

  function setTheme(t) {
    html.setAttribute('data-theme', t);
    sun.style.display  = t === 'dark' ? 'none' : 'block';
    moon.style.display = t === 'dark' ? 'block': 'none';
  }

  // Sync icons with theme already set by BaseLayout's inline script
  setTheme(html.getAttribute('data-theme'));

  btn.addEventListener('click', () => {
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    localStorage.setItem('theme', next);
    setTheme(next);
  });

  // ── Info overlay ──
  const infoOverlay = document.getElementById('info-overlay');
  function openInfo() {
    infoOverlay.classList.add('open');
    infoOverlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }
  function closeInfo() {
    infoOverlay.classList.remove('open');
    infoOverlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }
  infoOverlay.addEventListener('click', function(e) {
    if (e.target === infoOverlay) closeInfo();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && infoOverlay.classList.contains('open')) closeInfo();
  });

  // ── Horizontal surface controller ──
  (function() {
    const viewport = document.querySelector('.surface-viewport');
    const scaler = document.querySelector('.surface-scaler');
    const track = document.querySelector('.surface-track');
    const scrubberTrack = document.querySelector('.scrubber-track');
    const scrubberPill = document.querySelector('.scrubber-pill');
    const panels = Array.from(document.querySelectorAll('.panel'));

    if (!viewport || !scaler || !track || !scrubberTrack || !scrubberPill || panels.length === 0) return;

    var HERO_TRAVEL = function() { return Math.min(window.innerWidth * 0.72, 920); };
    var SCALE_MIN = 40 / 72;
    var WHEEL_ACCELERATION = 0.16;
    var FRICTION = 0.9;
    var MAX_VELOCITY = 120;
    var STOP_THRESHOLD = 0.08;

    var state = { x: 0, velocity: 0, maxX: 0, ticking: false };

    function updateMaxX() {
      var lastPanel = panels[panels.length - 1];
      var lastPanelRight = lastPanel.offsetLeft + lastPanel.offsetWidth;
      var rightPadding = window.innerWidth * 0.4 - 32;
      state.maxX = Math.max(0, lastPanelRight + rightPadding - viewport.clientWidth / SCALE_MIN);
    }

    function measure() {
      updateMaxX();
      state.x = Math.min(state.x, state.maxX);
      if (state.x === 0 || state.x === state.maxX) state.velocity = 0;
    }

    function onWheel(event) {
      if (window.innerWidth <= 980 || state.maxX <= 0) return;
      var dominantDelta = Math.abs(event.deltaY) > Math.abs(event.deltaX) ? event.deltaY : event.deltaX;
      if (dominantDelta === 0) return;
      event.preventDefault();
      updateMaxX();
      state.velocity = Math.max(-MAX_VELOCITY, Math.min(MAX_VELOCITY, state.velocity + dominantDelta * WHEEL_ACCELERATION));
      requestTick();
    }

    function requestTick() {
      if (state.ticking) return;
      state.ticking = true;
      requestAnimationFrame(updateFrame);
    }

    function updateFrame() {
      updateMaxX();
      state.x += state.velocity;

      if (state.x <= 0) { state.x = 0; state.velocity = 0; }
      else if (state.x >= state.maxX) { state.x = state.maxX; state.velocity = 0; }
      else { state.velocity *= FRICTION; if (Math.abs(state.velocity) < STOP_THRESHOLD) state.velocity = 0; }

      track.style.setProperty('--track-x', state.x + 'px');
      renderHeroState();
      renderProgress();


      if (Math.abs(state.velocity) >= STOP_THRESHOLD) requestAnimationFrame(updateFrame);
      else state.ticking = false;
    }

    function renderHeroState() {
      var progress = Math.min(1, state.x / HERO_TRAVEL());
      var scale = 1 - progress * (1 - SCALE_MIN);
      var radius = 28 - progress * 4;
      scaler.style.transform = 'scale(' + scale + ')';
      panels.forEach(function(p) { p.style.borderRadius = radius + 'px'; });
    }

    function renderProgress() {
      if (state.maxX <= 0) { scrubberPill.style.left = '0px'; return; }
      var trackWidth = scrubberTrack.clientWidth;
      var pillWidth = scrubberPill.offsetWidth;
      var usable = trackWidth - pillWidth;
      var ratio = state.x / state.maxX;
      scrubberPill.style.left = (ratio * usable + pillWidth / 2) + 'px';
    }

    window.addEventListener('wheel', onWheel, { passive: false });

    // ── Scrubber drag ──
    var dragging = false;

    function onDragStart(e) {
      if (window.innerWidth <= 980 || state.maxX <= 0) return;
      e.preventDefault();
      dragging = true;
      state.velocity = 0;
      updatePositionFromEvent(e);
    }

    function onDragMove(e) {
      if (!dragging) return;
      e.preventDefault();
      updatePositionFromEvent(e);
    }

    function onDragEnd(e) {
      if (!dragging) return;
      dragging = false;
    }

    function updatePositionFromEvent(e) {
      var clientX = e.touches ? e.touches[0].clientX : e.clientX;
      var trackRect = scrubberTrack.getBoundingClientRect();
      var pillWidth = scrubberPill.offsetWidth;
      var usable = trackRect.width - pillWidth;
      var relativeX = clientX - trackRect.left - pillWidth / 2;
      var ratio = Math.max(0, Math.min(1, relativeX / usable));
      state.x = ratio * state.maxX;
      requestTick();
    }

    scrubberTrack.addEventListener('mousedown', onDragStart);
    scrubberTrack.addEventListener('touchstart', onDragStart, { passive: false });
    window.addEventListener('mousemove', onDragMove);
    window.addEventListener('touchmove', onDragMove, { passive: false });
    window.addEventListener('mouseup', onDragEnd);
    window.addEventListener('touchend', onDragEnd);
    window.addEventListener('resize', function() {
      measure();
      renderHeroState();
      renderProgress();

      track.style.setProperty('--track-x', state.x + 'px');
    });

    measure();
    renderHeroState();
    renderProgress();
    renderPanelFocus();
    track.style.setProperty('--track-x', '0px');
  })();

  // ── Page exit transition ──
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('a[data-transition="page"]').forEach(function(link) {
      link.addEventListener('click', function(e) {
        var href = link.getAttribute('href');
        if (!href || href.charAt(0) === '#') return;
        if (link.target === '_blank' || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
        e.preventDefault();
        document.body.classList.add('page-out');
        setTimeout(function() { window.location.href = href; }, 160);
      });
    });
  }

  // ── Scroll reveal (for any remaining .reveal elements) ──
  var io = new IntersectionObserver(function(entries) {
    entries.forEach(function(e) {
      if (e.isIntersecting) { e.target.classList.add('vis'); io.unobserve(e.target); }
    });
  }, { threshold: 0.07, rootMargin: '0px 0px -24px 0px' });
  document.querySelectorAll('.reveal').forEach(function(el) { io.observe(el); });
</script>
</BaseLayout>

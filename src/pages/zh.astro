---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="黄拓文"
  description="黄拓文 Trevor Huang — 悉尼大学项目管理硕士在读"
  lang="zh"
>

<style>
  /* ── HORIZONTAL SURFACE ────────────────────────── */
  .demo-shell {
    min-height: 100vh;
    padding: 0 32px;
    display: flex;
    flex-direction: column;
  }

  .demo-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 28px 32px 0;
    flex-shrink: 0;
  }

  .topbar-controls {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .scrubber-track {
    width: 100%;
    max-width: 200px;
    height: 20px;
    background: transparent;
    border-radius: 1.5px;
    position: relative;
    cursor: pointer;
    display: flex;
    align-items: center;
  }

  .scrubber-track::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    height: 3px;
    background: #D6D3D1;
    border-radius: 1.5px;
  }

  :global([data-theme="dark"]) .scrubber-track::before {
    background: #52525B;
  }

  .scrubber-pill {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translate(-50%, -50%);
    width: 48px;
    height: 14px;
    border-radius: 7px;
    background: #78716C;
    transition: left 120ms linear, transform 0.2s ease;
    cursor: grab;
    z-index: 1;
  }

  .scrubber-pill:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .scrubber-pill:active {
    cursor: grabbing;
    transform: translate(-50%, -50%) scale(1.1);
  }

  :global([data-theme="dark"]) .scrubber-pill {
    background: #A1A1AA;
  }

  .surface-viewport {
    height: min(72vh, 780px);
    overflow: hidden;
    position: relative;
    margin-top: 100px;
    margin-bottom: auto;
    margin-left: -32px;
    width: calc(100% + 32px);
  }

  .surface-scaler {
    height: 100%;
    transform-origin: left center;
    will-change: transform;
  }

  .surface-track {
    display: flex;
    align-items: stretch;
    gap: 28px;
    height: 100%;
    will-change: transform;
    transform: translate3d(calc(var(--track-x, 0px) * -1), 0, 0);
    padding-left: calc(20vw - 32px);
    padding-right: calc(30vw - 32px);
  }

  /* ── PANELS ──────────────────────────────────────── */
  .panel {
    flex: 0 0 auto;
    border: 1px solid var(--border);
    background: #f9f9f9;
    position: relative;
    overflow: hidden;
    width: min(80vw, 1240px);
    border-radius: 28px;
  }

  :global([data-theme="dark"]) .panel {
    background: #1c1c1c;
  }

  .panel-hero {
    padding: 48px 48px 40px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
  }

  .panel-standard {
    padding: 36px 32px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    overflow: hidden;
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }

  .panel-standard:hover {
    transform: scale(1.02);
    box-shadow: 0 18px 48px rgba(28, 25, 23, 0.10);
  }

  /* Light mode: non-Stories panels — subtle darken */
  .panel-standard:not([data-panel="stories"]):hover {
    background: #f3f3f3;
  }

  /* Stories panel hover: need !important to override inline style */
  [data-panel="stories"]:hover {
    background: #2a2a2a !important;
  }

  /* Dark mode: all panels — subtle brighten, need !important for Stories inline */
  :global([data-theme="dark"]) .panel-standard:hover {
    background: #2a2a2a !important;
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.30);
  }

  @media (prefers-reduced-motion: reduce) {
    .panel-standard:hover {
      transform: none;
    }
  }

  .panel-kicker {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--fg-3);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .panel-copy h1 {
    font-family: var(--f-display);
    font-size: clamp(72px, 8vw, 126px);
    line-height: 0.94;
    margin: 18px 0 24px;
    font-weight: 700;
  }

  .panel-lede {
    font-size: clamp(22px, 2.2vw, 36px);
    line-height: 1.18;
    max-width: 18ch;
    color: var(--fg);
  }

  .panel-standard h2 {
    font-family: 'Geist', 'Helvetica Neue', helvetica, arial, sans-serif;
    font-size: clamp(120px, 16vw, 220px);
    font-weight: 600;
    line-height: 0.85;
    margin: 0;
    white-space: nowrap;
  }

  .panel-standard p {
    font-family: 'Geist', 'Helvetica Neue', helvetica, arial, sans-serif;
    font-size: 15px;
    line-height: 1.4;
    color: var(--fg-2);
    text-align: left;
  }

  /* ── INFO OVERLAY ───────────────────────────────── */
  .info-overlay {
    position: fixed;
    inset: 0;
    z-index: 60;
    background: color-mix(in srgb, var(--bg) 94%, transparent);
    backdrop-filter: blur(12px);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.28s ease;
  }

  .info-overlay.open {
    opacity: 1;
    pointer-events: auto;
  }

  .info-sheet {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 60px 72px;
    max-width: 1060px;
    width: calc(100% - 48px);
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: 44px 56px;
    box-shadow: 0 24px 72px rgba(28, 25, 23, 0.10);
  }

  :global([data-theme="dark"]) .info-sheet {
    box-shadow: 0 24px 72px rgba(0, 0, 0, 0.30);
  }

  .info-col-label {
    font-family: var(--f-mono);
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-3);
    margin-bottom: 12px;
  }

  .info-col-body {
    font-size: 17px;
    color: var(--fg-2);
    line-height: 1.7;
  }

  .info-col-body a {
    color: var(--fg-2);
    text-decoration: none;
  }

  .info-col-body a:hover {
    color: var(--accent);
  }

  .info-close {
    position: absolute;
    top: 16px;
    right: 20px;
    background: none;
    border: 0;
    cursor: pointer;
    color: var(--fg-3);
    font-size: 20px;
    padding: 6px 12px;
  }

  @media (max-width: 640px) {
    .info-sheet {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 28px 24px;
    }
  }

  /* ── META PILLS ─────────────────────────────────── */
  .meta-pill {
    font-family: var(--f-mono);
    font-size: 11px;
    color: var(--fg-2);
    padding: 4px 10px;
    border: 1px solid var(--border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg) 88%, transparent);
  }

  /* ── HERO PANEL ─────────────────────────────────── */
  .panel-hero {
    background: #f9f9f9;
  }

  :global([data-theme="dark"]) .panel-hero {
    background: #1c1c1c;
  }

  .hero-text {
    font-family: 'Geist', 'Helvetica Neue', helvetica, arial, sans-serif;
    font-size: clamp(56px, 8vw, 96px);
    font-weight: 500;
    line-height: 1.1;
    color: #111;
    position: relative;
    z-index: 2;
  }

  :global([data-theme="dark"]) .hero-text {
    color: #f5f5f4;
  }

  .hero-circle {
    position: absolute;
    right: -8vw;
    top: 50%;
    transform: translateY(-50%);
    width: clamp(300px, 55vw, 700px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: #D0C4F0;
    z-index: 1;
  }

  :global([data-theme="dark"]) .hero-circle {
    background: #5B4A8C;
  }

  /* ── ENTRY ANIMATION ────────────────────────────── */
  .entry-hero-scale {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform-origin: center center;
    position: relative;
    z-index: 2;
  }

  .entry-accent-a {
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    height: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #D0C4F0;
    opacity: 0.85;
    transform-origin: center center;
  }

  :global([data-theme="dark"]) .entry-accent-a {
    background: #5B4A8C;
  }

  .entry-line {
    display: block;
    overflow: hidden;
  }

  .entry-line > span {
    display: inline-block;
  }

  @media (prefers-reduced-motion: no-preference) {
    .entry-hero {
      transform: scale(0);
      transform-origin: center center;
      animation: entryHeroScale 1200ms cubic-bezier(.2,.8,.2,1) forwards;
    }

    .entry-hero-scale {
      transform: scale(0);
      animation: entryHeroScale 700ms cubic-bezier(.2,.8,.2,1) 100ms forwards;
    }

    .entry-accent-a {
      transform: translateY(-50%) scale(0);
      animation: entryAccentScale 700ms cubic-bezier(.2,.8,.2,1) 400ms forwards;
    }

    .entry-line > span {
      transform: translateY(105%);
      animation: entryLineReveal 640ms cubic-bezier(.2,.8,.2,1) forwards;
    }

    .entry-line:nth-child(1) > span { animation-delay: 200ms; }
    .entry-line:nth-child(2) > span { animation-delay: 290ms; }
    .entry-line:nth-child(3) > span { animation-delay: 380ms; }
    .entry-line:nth-child(4) > span { animation-delay: 470ms; }
    .entry-line:nth-child(5) > span { animation-delay: 560ms; }

    .entry-panel {
      opacity: 0;
      animation: entryPanelFade 200ms ease-in-out 1100ms forwards;
    }
  }

  @keyframes entryHeroScale {
    to { transform: scale(1); }
  }

  @keyframes entryAccentScale {
    to { transform: translateY(-50%) scale(1); }
  }

  @keyframes entryLineReveal {
    to { transform: translateY(0); }
  }

  @keyframes entryPanelFade {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .entry-hero,
    .entry-hero-scale,
    .entry-accent-wrap {
      transform: none;
      animation: none;
    }
    .entry-accent-a {
      transform: translateY(-50%);
    }
    .entry-line > span {
      transform: none;
      animation: none;
    }
    .entry-panel {
      opacity: 1;
      animation: none;
    }
  }

  /* ── INFO TRIGGER ───────────────────────────────── */
  .info-trigger {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--fg-3);
    background: none;
    border: 0;
    cursor: pointer;
    padding: 4px 0;
    transition: color var(--t);
  }

  .info-trigger:hover {
    color: var(--fg);
  }

  /* ── NAV COMPACT ────────────────────────────────── */
  nav.compact{
    background:transparent;border-bottom-color:transparent;
  }

  nav.compact .nav-inner{
    height:46px;max-width:760px;padding:0 18px 0 20px;
    transform:translateY(10px);
    border-color:var(--border);border-radius:999px;
    background:color-mix(in srgb,var(--bg) 88%,transparent);
    box-shadow:0 14px 36px rgba(28,25,23,.08);
  }

  :global([data-theme="dark"]) nav.compact .nav-inner{box-shadow:0 14px 36px rgba(0,0,0,.28)}

  /* ── THEME TOGGLE ───────────────────────────────── */
  .tbtn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: auto;
    height: auto;
    border: none;
    background: transparent;
    color: var(--fg-2);
    padding: 4px;
    transition: color var(--t);
    margin-left: 6px;
  }

  .tbtn:hover {
    color: var(--fg);
    background: transparent;
    border: none;
  }

  /* ── MAIN TRANSITION (page exit) ────────────────── */
  main{
    transition:opacity .18s ease, transform .18s ease;
  }

  body.page-out main{
    opacity:0;
    transform:translateY(8px);
  }

  @media(prefers-reduced-motion:reduce){
    main{transition:none}
  }

  /* ── MOBILE OVERRIDES ──────────────────────────── */
  @media (max-width: 980px) {
    body {
      overflow: auto;
    }

    .surface-viewport {
      height: auto;
      overflow: visible;
      margin-left: 0;
      width: 100%;
      margin-top: 28px;
    }

    .surface-scaler {
      transform: none !important;
    }

    .surface-track {
      transform: none !important;
      display: grid;
      gap: 20px;
      padding-left: 0;
      padding-right: 0;
    }

    .panel-hero,
    .panel-standard {
      width: auto;
    }

    .panel-hero {
      grid-template-columns: 1fr;
    }
  }
</style>

<main>
  <!-- ═══════════ TOP BAR: SCRUBBER + CONTROLS ═══════════ -->
  <header class="demo-topbar" aria-label="Horizontal progress">

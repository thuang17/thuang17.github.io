---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Making — Trevor Huang"
  description="Trevor Huang — my journey with AI tools and making things."
>

<style>
  /* ── TOPBAR ──────────────────────────────────── */
  .topbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 50;
    display: flex; align-items: center; justify-content: space-between;
    padding: 24px 32px; pointer-events: none;
  }
  .topbar > * { pointer-events: auto; }
  .topbar-nav {
    font-family: var(--f-mono); font-size: 12px;
    color: var(--fg-2); background: none; border: none; cursor: inherit;
    display: flex; align-items: center; gap: 5px; transition: color .2s;
  }
  .topbar-nav:hover { color: var(--accent); }
  .topbar-right { display: flex; align-items: center; gap: 16px; }
  .lang-link {
    font-family: var(--f-mono); font-size: 12px;
    color: var(--fg-3); text-decoration: none; transition: color .2s;
  }
  .lang-link:hover { color: var(--accent); }
  .theme-btn {
    background: none; border: none; cursor: inherit;
    color: var(--fg-2); padding: 4px; display: flex; align-items: center; transition: color .2s;
  }
  .theme-btn:hover { color: var(--accent); }
  #icon-moon { display: none; }
  :global([data-theme="dark"]) #icon-sun  { display: none; }
  :global([data-theme="dark"]) #icon-moon { display: block; }

  /* ── MAIN LAYOUT ─────────────────────────────── */
  main { max-width: 680px; margin: 0 auto; padding: 0 32px; }
  .page-header-wrap { padding: 80px 0 64px; }
  .page-title {
    font-family: var(--f-display); font-size: 48px; font-weight: 400;
    line-height: 1.1; letter-spacing: -0.02em; color: var(--fg);
  }
  .page-bottom { padding-bottom: 120px; }

  /* ── TIMELINE ────────────────────────────────── */
  .timeline {
    position: relative; padding-left: 36px;
  }
  .timeline::before {
    content: '';
    position: absolute; left: 5px; top: 0; bottom: 0;
    width: 1.5px; background: var(--fg-3); opacity: 0.5;
  }
  .tl-item {
    position: relative; margin-bottom: 56px;
  }
  .tl-item:last-child { margin-bottom: 0; }
  .tl-dot {
    position: absolute; left: -36px; top: 6px;
    width: 11px; height: 11px; border-radius: 50%;
    background: transparent; border: 1px solid var(--border);
  }
  .cursor-dot {
    position: absolute; left: 5px; top: 0;
    width: 13px; height: 13px;
    border-radius: 50%; background: var(--accent);
    transform: translate(-50%, -50%);
    pointer-events: none; z-index: 5;
    will-change: top;
  }
  .tl-head {
    font-family: var(--f-display); font-size: 18px; font-weight: 400;
    color: var(--fg); margin-bottom: 4px; letter-spacing: -0.01em;
    line-height: 1.4;
  }
  .tl-body {
    font-family: var(--f-body); font-size: 15px; font-weight: 400;
    color: var(--fg-2); line-height: 1.7;
  }

  /* ── NAV OVERLAY ─────────────────────────────── */
  .nav-overlay { position: fixed; inset: 0; z-index: 60; background: rgba(0,0,0,0.2); display: none; align-items: flex-start; justify-content: flex-start; padding: 80px 32px; }
  .nav-overlay.open { display: flex; }
  .nav-panel { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 28px 32px; min-width: 220px; box-shadow: 0 8px 32px rgba(0,0,0,0.08); }
  .nav-panel a, .nav-panel button { display: block; font-family: var(--f-mono); font-size: 12px; color: var(--fg-2); text-decoration: none; background: none; border: none; cursor: inherit; padding: 5px 0; transition: color .15s; line-height: 1.6; width: 100%; text-align: left; }
  .nav-panel a:hover, .nav-panel button:hover { color: var(--accent); }
  .nav-panel .nav-section { font-family: var(--f-mono); font-size: 12px; color: var(--fg); padding: 8px 0 4px; }
  .nav-panel .nav-sub { padding-left: 14px; }
  .nav-panel .nav-current { color: var(--accent); }
  .nav-panel hr { border: none; border-top: 1px solid var(--border); margin: 8px 0; }

  /* ── INFO OVERLAY ────────────────────────────── */
  .info-overlay { position: fixed; inset: 0; z-index: 70; background: color-mix(in srgb, var(--bg) 50%, transparent); backdrop-filter: blur(12px); display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.28s ease; }
  .info-overlay.open { opacity: 1; pointer-events: auto; }
  .info-sheet { background: var(--bg); border: 1px solid var(--border); border-radius: 20px; padding: 60px 72px; position: relative; max-width: 1060px; width: calc(100% - 48px); display: grid; grid-template-columns: 1.25fr 0.75fr; gap: 44px 56px; box-shadow: 0 24px 72px rgba(28, 25, 23, 0.10); }
  :global([data-theme="dark"]) .info-sheet { box-shadow: 0 24px 72px rgba(0, 0, 0, 0.30); }
  .info-col-label { font-family: var(--f-mono); font-size: 12px; letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); margin-bottom: 12px; }
  .info-col-body { font-size: 17px; color: var(--fg-2); line-height: 1.7; }
  .info-col-body a { color: var(--fg-2); text-decoration: none; }
  .info-col-body a:hover { color: var(--accent); }
  .info-close { position: absolute; top: 16px; right: 20px; background: none; border: 0; cursor: inherit; color: var(--fg-3); font-size: 20px; padding: 6px 12px; }

  /* ── RESPONSIVE ──────────────────────────────── */
  @media (max-width: 680px) {
    .topbar { padding: 20px 20px; }
    main { padding: 0 20px; }
    .page-title { font-size: 36px; }
    .page-header-wrap { padding: 64px 0 48px; }
    .timeline { padding-left: 28px; }
    .tl-dot { left: -28px; width: 9px; height: 9px; }
    .tl-item { margin-bottom: 40px; }
    .info-sheet { grid-template-columns: 1fr; gap: 20px; padding: 28px 24px; }
  }
  @media (max-width: 480px) {
    .page-title { font-size: 32px; }
  }
</style>

<!-- ═══════════ TOPBAR ═══════════ -->
<header class="topbar">
  <button class="topbar-nav" onclick="toggleNav()" aria-label="Open navigation">
    <svg width="14" height="12" viewBox="0 0 14 12" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <line x1="0" y1="2" x2="14" y2="2"/>
      <line x1="0" y1="7" x2="14" y2="7"/>
      <line x1="4" y1="12" x2="14" y2="12"/>
    </svg>
  </button>
  <div class="topbar-right">
    <a href="/zh-ai" class="lang-link">中文</a>
    <button class="theme-btn" onclick="toggleTheme()" aria-label="Toggle theme">
      <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
  </div>
</header>

<main>
  <div class="page-header-wrap">
    <h1 class="page-title">Making</h1>
  </div>

  <div class="timeline">
    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-head">ChatGPT as a workaround</div>
      <div class="tl-body">IP blocks, account restrictions, the full mainland China experience. Used it like a smarter search engine. Useful, nothing more.</div>
    </div>

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-head">NotebookLM made the system visible</div>
      <div class="tl-body">Feed it PDFs and documents, make it answer from sources. For research and report writing, that felt closer to working memory than a chatbot.</div>
    </div>

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-head">Prompts as thinking tools</div>
      <div class="tl-body">Context, constraints, examples, tone, order of questions. Most people skip that layer. I found it worth learning.</div>
    </div>

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-head">Claude moved it to execution</div>
      <div class="tl-body">The barrier wasn't "I can't code." It was whether I could describe the outcome clearly, review what changed, and keep iterating.</div>
    </div>

    <div class="tl-item">
      <div class="tl-dot"></div>
      <div class="tl-head">First product in a weekend</div>
      <div class="tl-body">Personal budget tracker. Idea to shipped in two days. Smaller, messier, faster than any BRD I wrote at Decathlon. It made building feel reachable.</div>
    </div>

    <div class="cursor-dot" id="cursorDot"></div>
  </div>

  <div class="page-bottom"></div>
</main>

<!-- ═══════════ NAV OVERLAY ═══════════ -->
<div class="nav-overlay" id="navOverlay" onclick="closeNav(event)">
  <div class="nav-panel" onclick="event.stopPropagation()">
    <a href="/" class="nav-section" style="padding-top:0">Homepage</a>
    <a href="/work" class="nav-section">Work</a>
    <a href="/decathlon" class="nav-sub">Decathlon</a>
    <a href="/mayora" class="nav-sub">Mayora</a>
    <a class="nav-sub" style="color:var(--fg-3);cursor:default;pointer-events:none;">SynTao</a>
    <a class="nav-sub" style="color:var(--fg-3);cursor:default;pointer-events:none;">Tianfeng Securities</a>
    <hr>
    <a href="/ai" class="nav-section nav-current">Making</a>
    <a href="/stories" class="nav-section">Stories</a>
    <button onclick="toggleInfo()" class="nav-section" style="border:none;background:none;cursor:inherit;text-align:left;width:100%;">Info</button>
  </div>
</div>

<!-- ═══════════ INFO OVERLAY ═══════════ -->
<div class="info-overlay" id="infoOverlay" aria-hidden="true" onclick="closeInfo(event)">
  <div class="info-sheet" onclick="event.stopPropagation()">
    <button class="info-close" onclick="closeInfo()" aria-label="Close info">&times;</button>
    <div><div class="info-col-label">Education</div><div class="info-col-body"><strong>University of Sydney</strong><br><span style="color:var(--fg-3);font-size:14px">2025–2027 · Master of Project Management</span><br><br><strong>Shanghai University of International Business and Trade</strong><br><span style="color:var(--fg-3);font-size:14px">2020–2024 · Bachelor of International Economics and Trade</span></div></div>
    <div><div class="info-col-label">Contact &amp; Social</div><div class="info-col-body"><a href="mailto:trevor.tw.huang@outlook.com">trevor.tw.huang@outlook.com</a><br><a href="https://linkedin.com/in/trevor0h17/" target="_blank" rel="noopener">LinkedIn</a> &nbsp;·&nbsp; <a href="https://www.instagram.com/t.huang17/" target="_blank" rel="noopener">Instagram</a><br><a href="https://x.com/H3art128943" target="_blank" rel="noopener">X</a> &nbsp;·&nbsp; <a href="https://www.xiaohongshu.com/user/profile/6150a3e2000000001f03501f" target="_blank" rel="noopener">Xiaohongshu</a></div></div>
    <div style="grid-column:1/-1"><div class="info-col-label">Toolkit</div><div class="info-col-body">Python · SQL · Tableau · Excel · Jira · Feishu · MS Project<br>Agile Methodologies</div></div>
  </div>
</div>

<script is:inline>
  // ── Theme: sync icons with theme already set by BaseLayout ──
  (function() {
    var el = document.documentElement;
    var t = el.getAttribute('data-theme') || 'light';
    var sun = document.getElementById('icon-sun');
    var moon = document.getElementById('icon-moon');
    if (sun) sun.style.display = t === 'dark' ? 'none' : 'block';
    if (moon) moon.style.display = t === 'dark' ? 'block' : 'none';
  })();

  function toggleTheme() {
    var el = document.documentElement;
    var next = el.dataset.theme === 'dark' ? 'light' : 'dark';
    el.dataset.theme = next; localStorage.setItem('theme', next);
    var sun = document.getElementById('icon-sun');
    var moon = document.getElementById('icon-moon');
    if (sun) sun.style.display = next === 'dark' ? 'none' : 'block';
    if (moon) moon.style.display = next === 'dark' ? 'block' : 'none';
  }

  // ── Cursor dot ──
  (function() {
    var dot = document.getElementById('cursorDot');
    var timeline = document.querySelector('.timeline');
    if (!dot || !timeline) return;
    var mouseY = 0;
    document.addEventListener('mousemove', function(e) { mouseY = e.clientY; });
    function frame() {
      var r = timeline.getBoundingClientRect();
      var relY = mouseY - r.top;
      var clampedY = Math.max(0, Math.min(relY, r.height));
      dot.style.top = clampedY + 'px';
      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  })();

  // ── Nav & Info overlays ──
  function toggleNav() { document.getElementById('navOverlay').classList.toggle('open'); }
  function closeNav(e) { if (!e || e.target === document.getElementById('navOverlay')) { document.getElementById('navOverlay').classList.remove('open'); } }
  function toggleInfo() { document.getElementById('navOverlay').classList.remove('open'); document.getElementById('infoOverlay').classList.toggle('open'); }
  function closeInfo(e) { if (!e || e.target === document.getElementById('infoOverlay')) { document.getElementById('infoOverlay').classList.remove('open'); } }
</script>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={`${entry.data.title} — Trevor Huang`} description={entry.data.description}>

<style>
  .product-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 64px 48px;
  }
  .product-page h1 {
    font-family: var(--f-display);
    font-size: clamp(32px, 4vw, 42px);
    font-weight: 700;
    margin-bottom: 8px;
  }
  .product-page .meta {
    font-family: var(--f-mono);
    font-size: 12px;
    color: var(--fg-3);
    margin-bottom: 4px;
  }
  .product-page .tags {
    margin: 12px 0 32px;
  }
  .product-page .content {
    font-size: 17px;
    line-height: 1.8;
    color: var(--fg-2);
  }
  .product-page .content h2 {
    font-family: var(--f-display);
    font-size: 22px;
    font-weight: 700;
    margin: 32px 0 12px;
    color: var(--fg);
  }
  .product-page .content p {
    margin-bottom: 16px;
  }
</style>

<div class="product-page">
  <div class="meta">{entry.data.status === 'building' ? 'Building' : entry.data.status === 'live' ? 'Live' : 'Archived'}</div>
  <h1>{entry.data.title}</h1>
  <p style="color:var(--fg-2);font-size:15px;margin-bottom:4px">{entry.data.description}</p>
  <div class="meta">{entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
  <div class="tags">
    {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
  <hr style="border:none;border-top:1px solid var(--border);margin:24px 0">
  <div class="content">
    <Content />
  </div>
</div>

</BaseLayout>
